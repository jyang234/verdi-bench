# Structural contracts enforced in CI [master plan §3.3]. Stories add contracts
# as they land. Run with: uv run lint-imports
[importlinter]
root_packages =
    harness

[importlinter:contract:harbor-confined-to-seam]
name = Harbor is imported only by the run engine seam [EVAL-4 AC-1]
type = forbidden
# Only DIRECT imports of harbor are forbidden; reaching HarborEngine through the
# engine factory (harness.run.engines) is exactly the allowed seam — callers ask
# for an engine by name and never import harbor themselves. The AST seam test
# (tests/test_eval4_seam.py) is the belt-and-suspenders guard that no module
# outside harbor.py / engines/__init__.py NAMES harbor at all.
allow_indirect_imports = True
source_modules =
    harness.cli
    harness.cli_common
    harness.entrypoints
    harness._entrypoint_fixtures
    harness.version
    harness.http_guard
    harness.schema
    harness.ledger
    harness.plan
    harness.adapters
    harness.grade
    harness.judge
    harness.analyze
    harness.review
    harness.process
    harness.corpus
    harness.contamination
    harness.blind
    harness.forensics
    harness.run.seam
    harness.run.interleave
    harness.run.budget
    harness.run.cli
    harness.run.api
    harness.run.egress
    harness.run.redact
    harness.run.types
    harness.run.settings
    harness.run.trajectory
    harness.run.heartbeat
    harness.run.engines.base
    harness.run.engines.fake
    harness.status
    harness.serve
    harness.author
    harness.sdk
    harness.hermetic
    harness.images
    harness.webkit
forbidden_modules =
    harness.run.engines.harbor

[importlinter:contract:grade-has-no-llm-clients]
name = Deterministic grading imports no LLM client [EVAL-5 constraint]
type = forbidden
# harness.hermetic.otlp_decode is the sole internal gateway to opentelemetry-proto
# (the lazy protobuf import lives there), so forbidding it keeps deterministic
# grading free of both the span decoder and its optional heavy dep [refactor 09 §6].
source_modules =
    harness.grade
forbidden_modules =
    harness.judge.providers
    harness.judge.client
    harness.hermetic.otlp_decode

[importlinter:contract:judge-imports-no-span-decoder]
name = The identity-blind judge imports no OTLP span decoder [refactor 09 §6]
type = forbidden
# otlp_spans.json is operator/forensics-tier: raw spans name models and vendors
# (gen_ai.request.model, service.name), so they must never enter the judge packet.
# The judge importing the span decoder would be the structural path to that leak;
# forbidding otlp_decode (the sole gateway to opentelemetry-proto) blocks it.
source_modules =
    harness.judge
forbidden_modules =
    harness.hermetic.otlp_decode

[importlinter:contract:contamination-detectors-have-no-llm-clients]
name = Deterministic contamination detectors import no LLM client [EVAL-10 AC-6]
# The probe module (and the CLI that drives it) is the story's ONLY LLM-touching
# surface — it is deliberately absent from this source list, exactly as
# harness.process legitimately uses the provider seam. The detectors (dating,
# canary derivation, overlap, summary) must stay deterministic.
type = forbidden
source_modules =
    harness.contamination.dating
    harness.contamination.canary
    harness.contamination.overlap
    harness.contamination.channels
    harness.contamination.scan
    harness.contamination.summary
forbidden_modules =
    harness.judge.providers
    harness.judge.client

[importlinter:contract:ledger-writes-only-via-events]
name = Ledger appends flow only through typed constructors [EVAL-3]
type = forbidden
# Only DIRECT imports of chain are forbidden; reaching chain transitively
# through the typed constructors in events.py is exactly the allowed path.
allow_indirect_imports = True
source_modules =
    harness.cli
    harness.cli_common
    harness.entrypoints
    harness._entrypoint_fixtures
    harness.version
    harness.http_guard
    harness.schema
    harness.plan
    harness.run
    harness.adapters
    harness.grade
    harness.judge
    harness.analyze
    harness.review
    harness.process
    harness.corpus
    harness.contamination
    harness.blind
    harness.forensics
    harness.status
    harness.serve
    harness.author
    harness.sdk
    harness.hermetic
    harness.images
    harness.webkit
forbidden_modules =
    harness.ledger.chain

[importlinter:contract:forensics-deterministic-tier-llm-free]
name = Deterministic forensics imports no LLM client [EVAL-11 AC-3]
type = forbidden
# The assembler is the deterministic ledger+disk → TrialEvidence phase [refactor
# 06 §5]: it prepares (splices, byte-budgets) the transcript but requests no
# completion — the advisory pass (review.py) is the sole provider-touching phase.
source_modules =
    harness.forensics.metrics
    harness.forensics.detectors
    harness.forensics.assembler
forbidden_modules =
    harness.judge.providers
    harness.judge.client

[importlinter:contract:reviewer-surface-isolated]
name = The reviewer surface never imports the unblinded operator tier [EVAL-18 AC-1]
# Strict (indirect chains included): a blinded capture surface that could
# reach the operator observer's modules — plaintext arm identities, feeds,
# comparisons — would make its isolation a discipline instead of a property.
type = forbidden
source_modules =
    harness.review
forbidden_modules =
    harness.serve
    harness.status
    harness.author

[importlinter:contract:observability-llm-free]
name = Read-only observability imports no LLM client [EVAL-13 AC-7]
type = forbidden
# Only DIRECT imports are forbidden (the contracts-1/4 mode): status reuses the
# EVAL-6 selfcheck classifier, whose analyze module reaches the provider seam
# transitively through forensics' advisory review — a legitimate chain the
# observer never executes. What this contract refuses is observability code
# naming an LLM client itself.
allow_indirect_imports = True
source_modules =
    harness.status
    harness.serve
forbidden_modules =
    harness.judge.providers
    harness.judge.client

[importlinter:contract:authoring-and-review-llm-free]
name = The authoring ceremony and reviewer surface import no LLM client [F-M-T3]
# Direct-import ban (same mode as observability-llm-free): the mutating
# pre-registration surface (author) and the blinded reviewer surface (review)
# have no business naming an LLM client — a future import would silently give
# a judge model a hand in pre-registration or blinded review.
type = forbidden
allow_indirect_imports = True
source_modules =
    harness.author
    harness.review
forbidden_modules =
    harness.judge.providers
    harness.judge.client

[importlinter:contract:sdk-is-a-leaf]
name = The SDK facade is a leaf consumer — no subsystem imports it [refactor 02 §1, master plan §3, A5]
# sdk composes and re-exports subsystems; the import direction is strictly
# sdk -> subsystems, never the reverse. Every other harness package (the
# subsystems AND the peer surfaces, incl. cli — `bench init` reads the template
# data FILES, it does not import the sdk package) is forbidden from importing
# harness.sdk. This also covers the plan's explicit "review must not import sdk".
type = forbidden
source_modules =
    harness.cli
    harness.cli_common
    harness.entrypoints
    harness._entrypoint_fixtures
    harness.version
    harness.http_guard
    harness.schema
    harness.ledger
    harness.plan
    harness.run
    harness.adapters
    harness.grade
    harness.judge
    harness.analyze
    harness.review
    harness.process
    harness.corpus
    harness.contamination
    harness.blind
    harness.forensics
    harness.status
    harness.serve
    harness.author
    harness.hermetic
    harness.images
    harness.webkit
forbidden_modules =
    harness.sdk
